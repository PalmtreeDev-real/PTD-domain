prompt_license() {
    echo -e "${YELLOW}========================================${NC}"
    echo -e "${YELLOW} License Agreement${NC}"
    echo -e "${YELLOW}========================================${NC}"
    echo ""
    echo "This .PTD (PalmtreeDev Domain) system is provided under the"
    echo "Apache License, Version 2.0."
    echo ""
    echo "You must read and accept the license terms before installing."
    echo ""

    while true; do
        read -r -p "Do you accept the Apache License 2.0? (yes/no): " answer
        case "$answer" in
            yes|Yes|YES|y|Y)
                echo ""
                success "License accepted. Proceeding with installation..."
                echo ""
                return 0
                ;;
            no|No|NO|n|N)
                echo ""
                die "License rejected. Installation cancelled."
                ;;
            *)
                echo "Please answer 'yes' or 'no'."
                ;;
        esac
    done
}

cmd_install() {
    check_root install

    show_license
    prompt_license

    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN} .ptd Local TLD Installer${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo ""

    install_packages

    mkdir -p "$STATE_DIR"

    # Detect and save upstream DNS before making any changes
    info "Detecting upstream DNS servers..."
    detect_upstream_dns > "$UPSTREAM_DNS_FILE"
    local count
    count=$(wc -l < "$UPSTREAM_DNS_FILE")
    info "  Found $count upstream DNS server(s)"

    configure_dnsmasq

    # Check port 53 before starting dnsmasq
    if command -v ss &>/dev/null && ss -tlnp 'sport = :domain' 2>/dev/null | grep -q LISTEN; then
        warn "Port 53 (DNS) is already in use:"
        ss -tlnp 'sport = :domain' 2>/dev/null | head -3
        warn "dnsmasq may fail to start. Check: journalctl -u dnsmasq"
    fi

    enable_and_start dnsmasq

    # Ensure dnsmasq is running before changing system DNS
    if ! systemctl is-active --quiet dnsmasq 2>/dev/null; then
        die "dnsmasq failed to start. Check: journalctl -u dnsmasq -n 30 --no-pager"
    fi

    configure_system_dns

    configure_nginx
    fix_selinux_context "$PTD_ROOT"
    enable_and_start nginx

    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN} Installation complete!${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo ""
    echo "  Create a project:   sudo ptd add myproject"
    echo "  Visit it at:        http://myproject.ptd/"
    echo "  List projects:      ptd list"
    echo "  Check status:       ptd status"
    echo "  Remove all:         sudo ptd uninstall"
    echo ""
}

cmd_uninstall() {
    check_root uninstall

    echo ""
    echo -e "${YELLOW}========================================${NC}"
    echo -e "${YELLOW} .ptd Local TLD Uninstaller${NC}"
    echo -e "${YELLOW}========================================${NC}"
    echo ""

    info "Stopping services..."
    for svc in dnsmasq nginx; do
        systemctl stop "$svc" 2>/dev/null || true
        systemctl disable "$svc" 2>/dev/null || true
    done

    info "Removing configuration files..."
    rm -f "$DNSMASQ_CONF"
    rm -f "$NGINX_CONF"

    restore_system_dns

    rm -rf "$STATE_DIR"

    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN} Uninstall complete${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo ""
    echo "  Configuration files removed."
    echo "  DNS settings restored."
    echo ""
    echo "  Packages were NOT removed. To remove them:"
    echo "    sudo zypper rm dnsmasq nginx"
    echo ""
    echo "  Project files were NOT removed. To remove them:"
    echo "    sudo rm -rf $PTD_ROOT"
    echo ""
}

cmd_add() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        die "Usage: ptd add <project-name>"
    fi

    if [[ ! "$name" =~ ^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?$ ]]; then
        die "Invalid project name. Use only letters, numbers, and hyphens (no leading/trailing hyphens)."
    fi

    local project_dir="$PTD_ROOT/$name"

    if [[ -d "$project_dir" ]]; then
        die "Project '$name' already exists at $project_dir"
    fi

    mkdir -p "$project_dir"

    cat > "$project_dir/index.html" <<- EOF
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>$name.ptd</title>
<style>
body { font-family: system-ui, -apple-system, sans-serif; max-width: 640px; margin: 3em auto; padding: 0 2em; line-height: 1.6; color: #e0e0e0; background: #0d1117; }
h1 { color: #58a6ff; }
code { background: #21262d; padding: 0.2em 0.5em; border-radius: 4px; }
a { color: #58a6ff; }
.card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1.5em 2em; margin: 1.5em 0; }
</style>
</head>
<body>
<div class="card">
<h1>$name.ptd</h1>
<p>Welcome to <strong>$name.ptd</strong>!</p>
<p>Edit files in <code>$project_dir</code></p>
<p>License: <a href="https://www.apache.org/licenses/LICENSE-2.0" target="_blank" rel="noopener">Apache 2.0</a></p>
</div>
</body>
</html>
EOF

    chmod 755 "$project_dir"
    chmod 644 "$project_dir/index.html"
    fix_selinux_context "$project_dir"

    echo ""
    echo -e "${GREEN}Project created!${NC}"
    echo "  Directory: $project_dir"
    echo "  URL:       http://$name.ptd/"
    echo ""
}

cmd_remove() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        die "Usage: ptd remove <project-name>"
    fi

    local project_dir="$PTD_ROOT/$name"

    if [[ ! -d "$project_dir" ]]; then
        die "Project '$name' not found at $project_dir"
    fi

    rm -rf "$project_dir"
    echo "Project '$name' removed."
}

cmd_list() {
    if [[ ! -d "$PTD_ROOT" ]]; then
        echo "No .ptd projects directory found."
        echo "Run 'sudo ptd install' to set up .ptd support."
        exit 0
    fi

    local projects
    projects=$(find "$PTD_ROOT" -maxdepth 1 -mindepth 1 -type d | sort)

    if [[ -z "$projects" ]]; then
        echo "No .ptd projects found."
        echo "Create one with: sudo ptd add <project-name>"
        exit 0
    fi

    echo ""
    echo -e "${CYAN}.ptd Projects:${NC}"
    echo ""
    printf "  %-24s %s\n" "Name" "URL"
    printf "  %-24s %s\n" "----" "---"
    while IFS= read -r proj; do
        local name
        name=$(basename "$proj")
        printf "  %-24s http://%s.ptd/\n" "$name" "$name"
    done <<< "$projects"
    echo ""
}

cmd_status() {
    echo ""
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN} .ptd Status${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo ""

    printf "  %-20s" "dnsmasq:"
    if systemctl is-active --quiet dnsmasq 2>/dev/null; then
        echo -e " ${GREEN}ACTIVE${NC}"
    else
        echo -e " ${RED}INACTIVE${NC} (run: sudo ptd install)"
    fi

    printf "  %-20s" "nginx:"
    if systemctl is-active --quiet nginx 2>/dev/null; then
        echo -e " ${GREEN}ACTIVE${NC}"
    else
        echo -e " ${RED}INACTIVE${NC} (run: sudo ptd install)"
    fi

    echo ""
    printf "  %-20s" "DNS (.ptd):"
    if command -v host &>/dev/null; then
        if host test.ptd 127.0.0.1 &>/dev/null; then
            echo -e " ${GREEN}WORKING${NC} (test.ptd -> 127.0.0.1)"
        else
            echo -e " ${RED}NOT RESOLVING${NC}"
        fi
    elif command -v nslookup &>/dev/null; then
        if nslookup test.ptd 127.0.0.1 &>/dev/null; then
            echo -e " ${GREEN}WORKING${NC} (test.ptd -> 127.0.0.1)"
        else
            echo -e " ${RED}NOT RESOLVING${NC}"
        fi
    else
        echo "install bind-utils to verify"
    fi

    echo ""
    local project_count=0
    if [[ -d "$PTD_ROOT" ]]; then
        project_count=$(find "$PTD_ROOT" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
    fi
    echo "  Projects:      $project_count"

    if [[ $project_count -gt 0 ]]; then
        echo ""
        echo "  Projects:"
        while IFS= read -r proj; do
            local name
            name=$(basename "$proj")
            echo "    - http://$name.ptd/"
        done < <(find "$PTD_ROOT" -maxdepth 1 -mindepth 1 -type d | sort)
    fi
    echo ""
}

cmd_restart() {
    check_root restart

    info "Restarting services..."
    for svc in dnsmasq nginx; do
        systemctl restart "$svc" 2>/dev/null && success "$svc restarted" || warn "Failed to restart $svc"
    done
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 1
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        install)
            cmd_install "$@"
            ;;
        uninstall)
            cmd_uninstall "$@"
            ;;
        add)
            check_root add
            cmd_add "$@"
            ;;
        remove)
            check_root remove
            cmd_remove "$@"
            ;;
        list)
            cmd_list "$@"
            ;;
        status)
            cmd_status "$@"
            ;;
        restart)
            cmd_restart "$@"
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            die "Unknown command: $cmd. Use 'ptd help' for usage."
            ;;
    esac
}

main "$@"

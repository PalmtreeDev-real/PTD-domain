#!/bin/bash
#
# ptd - PalmTreeDev Domain (.ptd) local TLD manager
# Version 1.0.0
#
# Automates creation and management of a local-only .ptd top-level domain
# on openSUSE Tumbleweed using dnsmasq + nginx.
#
# Usage: ptd <command> [<args>]
#
# Commands:
#   install          Set up dnsmasq + nginx + system DNS for .ptd
#   uninstall        Remove all .ptd configuration and restore system
#   add <name>       Create a new .ptd project in /var/www/ptd/<name>/
#   remove <name>    Delete a .ptd project
#   list             List all .ptd projects
#   status           Show service and DNS status
#   restart          Restart dnsmasq + nginx services
#   help             Show this help message

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
readonly PTD_ROOT="/var/www/ptd"
readonly DNSMASQ_CONF="/etc/dnsmasq.d/ptd.conf"
readonly NGINX_CONF="/etc/nginx/conf.d/ptd.conf"
readonly STATE_DIR="/var/lib/ptd"
readonly ORIG_DNS_FILE="$STATE_DIR/orig_dns"
readonly UPSTREAM_DNS_FILE="$STATE_DIR/upstream_dns"

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m'

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: ptd <command> [<args>]

Commands:
    install          Install and configure DNS + web server for .ptd TLD
    uninstall        Remove all .ptd configuration and restore system DNS
    add <name>       Create a new .ptd project served at http://<name>.ptd/
    remove <name>    Delete a .ptd project
    list             List all .ptd projects
    status           Show service, DNS, and project status
    restart          Restart dnsmasq and nginx services
    help             Show this help message

Examples:
    sudo ptd install
    sudo ptd add myproject     # http://myproject.ptd/
    ptd list
    sudo ptd remove myproject
    sudo ptd uninstall

Files:
    Projects root:  $PTD_ROOT
    DNS config:     $DNSMASQ_CONF
    Nginx config:   $NGINX_CONF
EOF
}

die() {
    echo -e "${RED}Error: $*${NC}" >&2
    exit 1
}

warn() {
    echo -e "${YELLOW}Warning: $*${NC}"
}

info() {
    echo -e "${CYAN}==>${NC} $*"
}

success() {
    echo -e "${GREEN}==>${NC} $*"
}

check_root() {
    if [[ $EUID -ne 0 ]]; then
        die "This command requires root privileges. Run with: sudo ptd $*"
    fi
}

# ---------------------------------------------------------------------------
# DNS helpers
# ---------------------------------------------------------------------------
detect_upstream_dns() {
    local dns_servers=()
    local ns

    # Method 1: systemd-resolved
    if command -v resolvectl &>/dev/null; then
        while IFS= read -r line; do
            if [[ $line =~ ^[[:space:]]*DNS[[:space:]]+Servers:[[:space:]]*(.+) ]]; then
                for ns in ${BASH_REMATCH[1]}; do
                    if [[ "$ns" != "127.0.0.1" && "$ns" != "127.0.0.53" && "$ns" != "::1" ]]; then
                        dns_servers+=("$ns")
                    fi
                done
            fi
        done < <(resolvectl status 2>/dev/null || true)
    fi

    # Method 2: NetworkManager
    if [[ ${#dns_servers[@]} -eq 0 ]] && command -v nmcli &>/dev/null; then
        local devs
        devs=$(nmcli -t -f DEVICE device status 2>/dev/null | grep -v '^lo$' | grep -v '^$' || true)
        while IFS= read -r dev; do
            [[ -z "$dev" ]] && continue
            while IFS= read -r dns_line; do
                ns="${dns_line#DNS:}"
                if [[ "$ns" != "127.0.0.1" && "$ns" != "127.0.0.53" && "$ns" != "::1" && -n "$ns" ]]; then
                    dns_servers+=("$ns")
                fi
            done < <(nmcli -t device show "$dev" 2>/dev/null | grep '^DNS:' || true)
        done <<< "$devs"
    fi

    # Method 3: /etc/resolv.conf
    if [[ ${#dns_servers[@]} -eq 0 ]] && [[ -f /etc/resolv.conf ]]; then
        while read -r line; do
            if [[ $line =~ ^nameserver\ +(.+) ]]; then
                ns="${BASH_REMATCH[1]}"
                if [[ "$ns" != "127.0.0.1" && "$ns" != "127.0.0.53" && "$ns" != "::1" ]]; then
                    dns_servers+=("$ns")
                fi
            fi
        done < /etc/resolv.conf
    fi

    # Default fallbacks
    if [[ ${#dns_servers[@]} -eq 0 ]]; then
        dns_servers=("8.8.8.8" "1.1.1.1")
    fi

    printf '%s\n' "${dns_servers[@]}"
}

configure_dnsmasq() {
    info "Configuring dnsmasq..."

    local upstream
    upstream=$(cat "$UPSTREAM_DNS_FILE")

    cat > "$DNSMASQ_CONF" <<- EOF
# .ptd local TLD configuration
# Created by ptd on $(date)

# Listen on localhost only
listen-address=127.0.0.1
bind-interfaces
port=53

# Disable DHCP on loopback
no-dhcp-interface=lo

# Security hardening
domain-needed
bogus-priv
no-resolv

# Cache settings
cache-size=1000
neg-ttl=60

# Wildcard .ptd -> 127.0.0.1
address=/ptd/127.0.0.1

# Upstream DNS servers
EOF

    while IFS= read -r ns; do
        [[ -z "$ns" ]] && continue
        echo "server=$ns" >> "$DNSMASQ_CONF"
    done <<< "$upstream"

    success "dnsmasq config written: $DNSMASQ_CONF"
}

configure_system_dns() {
    info "Configuring system DNS to use local dnsmasq (127.0.0.1)..."

    mkdir -p "$STATE_DIR"
    : > "$ORIG_DNS_FILE"   # clear file

    if command -v nmcli &>/dev/null && nmcli -t -f RUNNING general 2>/dev/null | grep -q running; then
        info "NetworkManager detected — updating connection DNS settings..."

        local connections
        connections=$(nmcli -t -f NAME con show --active 2>/dev/null || true)

        if [[ -z "$connections" ]]; then
            warn "No active NetworkManager connections found."
            warn "DNS changes will not take effect until a connection is active."
            return
        fi

        while IFS= read -r conn; do
            [[ -z "$conn" ]] && continue

            local orig_dns orig_ignore
            orig_dns=$(nmcli -g ipv4.dns con show "$conn" 2>/dev/null || true)
            orig_ignore=$(nmcli -g ipv4.ignore-auto-dns con show "$conn" 2>/dev/null || true)

            echo "CONN:$conn|dns=$orig_dns|ignore-auto=$orig_ignore" >> "$ORIG_DNS_FILE"

            nmcli con mod "$conn" ipv4.dns "127.0.0.1" 2>/dev/null
            nmcli con mod "$conn" ipv4.ignore-auto-dns yes 2>/dev/null
            info "  Updated connection: $conn"
        done <<< "$connections"

        info "Restarting connections to apply DNS changes..."
        while IFS= read -r conn; do
            [[ -z "$conn" ]] && continue
            nmcli con down "$conn" 2>/dev/null || true
            nmcli con up "$conn" 2>/dev/null || true
        done <<< "$connections"

    elif [[ -f /etc/sysconfig/network/config ]]; then
        info "Using netconfig to set DNS..."

        local orig
        orig=$(grep '^NETCONFIG_DNS_STATIC_SERVERS=' /etc/sysconfig/network/config 2>/dev/null | sed 's/^NETCONFIG_DNS_STATIC_SERVERS=//' | tr -d '"')
        echo "NETCONFIG:$orig" >> "$ORIG_DNS_FILE"

        sed -i 's/^NETCONFIG_DNS_STATIC_SERVERS=.*/NETCONFIG_DNS_STATIC_SERVERS="127.0.0.1"/' /etc/sysconfig/network/config
        netconfig update 2>/dev/null || true

    else
        warn "Could not detect NetworkManager or netconfig."
        warn "Please manually set your system DNS to 127.0.0.1 (first nameserver)."
    fi

    success "System DNS configured to use 127.0.0.1"
}

restore_system_dns() {
    if [[ ! -f "$ORIG_DNS_FILE" ]]; then
        warn "No saved DNS configuration found; nothing to restore."
        return
    fi

    info "Restoring original system DNS settings..."

    if command -v nmcli &>/dev/null && nmcli -t -f RUNNING general 2>/dev/null | grep -q running; then
        while IFS='|' read -r entry; do
            [[ -z "$entry" ]] && continue
            if [[ "$entry" =~ ^CONN:(.+)\|dns=(.*)\|ignore-auto=(.*)$ ]]; then
                local conn="${BASH_REMATCH[1]}"
                local orig_dns="${BASH_REMATCH[2]}"
                local orig_ignore="${BASH_REMATCH[3]}"

                if [[ -n "$orig_dns" ]]; then
                    nmcli con mod "$conn" ipv4.dns "$orig_dns" 2>/dev/null || true
                else
                    nmcli con mod "$conn" ipv4.dns "" 2>/dev/null || true
                fi

                if [[ -n "$orig_ignore" ]]; then
                    nmcli con mod "$conn" ipv4.ignore-auto-dns "$orig_ignore" 2>/dev/null || true
                else
                    nmcli con mod "$conn" ipv4.ignore-auto-dns no 2>/dev/null || true
                fi

                nmcli con down "$conn" 2>/dev/null || true
                nmcli con up "$conn" 2>/dev/null || true
            fi
        done < "$ORIG_DNS_FILE"

    elif [[ -f /etc/sysconfig/network/config ]]; then
        local orig
        orig=$(grep '^NETCONFIG:' "$ORIG_DNS_FILE" 2>/dev/null | sed 's/^NETCONFIG://')
        if [[ -n "$orig" ]]; then
            sed -i "s/^NETCONFIG_DNS_STATIC_SERVERS=.*/NETCONFIG_DNS_STATIC_SERVERS=\"$orig\"/" /etc/sysconfig/network/config
        else
            sed -i 's/^NETCONFIG_DNS_STATIC_SERVERS=.*/NETCONFIG_DNS_STATIC_SERVERS=""/' /etc/sysconfig/network/config
        fi
        netconfig update 2>/dev/null || true
    fi

    rm -f "$ORIG_DNS_FILE"
    success "System DNS restored"
}


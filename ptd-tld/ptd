# ---------------------------------------------------------------------------
# Package management
# ---------------------------------------------------------------------------
install_packages() {
    local pkgs=()

    if ! command -v dnsmasq &>/dev/null; then
        pkgs+=("dnsmasq")
    fi
    if ! command -v nginx &>/dev/null; then
        pkgs+=("nginx")
    fi

    if [[ ${#pkgs[@]} -gt 0 ]]; then
        info "Installing packages: ${pkgs[*]}..."
        zypper --non-interactive install "${pkgs[@]}" || die "Failed to install packages."
        success "Packages installed."
    else
        info "Required packages already installed."
    fi
}

# ---------------------------------------------------------------------------
# SELinux helpers
# ---------------------------------------------------------------------------
fix_selinux_context() {
    local target="${1:-$PTD_ROOT}"
    if command -v sestatus &>/dev/null && sestatus 2>/dev/null | grep -q 'enforcing'; then
        info "SELinux enforcing — setting httpd_sys_content_t on $target"
        if command -v chcon &>/dev/null; then
            chcon -R -t httpd_sys_content_t "$target" 2>/dev/null && \
                success "SELinux context set on $target" || \
                warn "Failed to set SELinux context (run manually if needed)"
            # Try to install policycoreutils for persistent labeling
            if ! command -v restorecon &>/dev/null && command -v zypper &>/dev/null; then
                zypper --non-interactive install -y policycoreutils 2>/dev/null || true
            fi
            if command -v semanage &>/dev/null && command -v restorecon &>/dev/null; then
                semanage fcontext -a -t httpd_sys_content_t "${target}(/.*)?" 2>/dev/null || true
                restorecon -R "$target" 2>/dev/null || true
                success "Persistent SELinux rule added"
            fi
        else
            warn "chcon not found. Install policycoreutils: sudo zypper install policycoreutils"
        fi
    fi
}

# ---------------------------------------------------------------------------
# Service helpers
# ---------------------------------------------------------------------------
enable_and_start() {
    local svc="$1"
    systemctl enable "$svc" 2>/dev/null || true
    systemctl restart "$svc" 2>/dev/null || warn "Failed to start $svc (check: journalctl -u $svc)"
    if systemctl is-active --quiet "$svc"; then
        success "$svc is running"
    fi
}

